<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Student Rental House Management System</display-name>
    <description>UMT CSM3023 – Student Rental House Management</description>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.rentalhouse.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HouseServlet</servlet-name>
        <servlet-class>com.rentalhouse.controller.HouseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HouseServlet</servlet-name>
        <url-pattern>/api/houses/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TenantServlet</servlet-name>
        <servlet-class>com.rentalhouse.controller.TenantServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TenantServlet</servlet-name>
        <url-pattern>/api/tenants/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ComplaintServlet</servlet-name>
        <servlet-class>com.rentalhouse.controller.ComplaintServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ComplaintServlet</servlet-name>
        <url-pattern>/api/complaints/*</url-pattern>
    </servlet-mapping>

    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>
</web-app>
